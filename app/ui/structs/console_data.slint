// Data from the console's CPU to display
export struct CpuData {
    pbr: string,
    pc: string,
    a: string,
    b: string,
    c: string,
    x: string,
    xl: string,
    xh: string,
    y: string,
    yl: string,
    yh: string
}
// Data from the console
export struct ConsoleData {cpu: CpuData}
