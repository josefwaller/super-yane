import { ComboBox, Button, CheckBox } from "std-widgets.slint";
import { Palette } from "../palette.slint";

// Types of binary data sources
export enum BinaryDataSourceType {
    Wram,
    Vram,
    Cgram,
    Cartridge
}
// All the information required to display a block of binary data, except the data itself
export struct BinaryDataSource { ramType: BinaryDataSourceType, page_offset: int, show_as_tile: bool}
/*
 * View Binary data as a table of bytes
 */
export component BinaryData {
    // The binary data to display, as hex strings
    in property <[[string]]> data;
    // The binary data to display, as an image
    in property <image> data_image;
    // The headers of the columns, including the top-left cell
    in property <[string]> column_headers;
    // The headers of the rows, excluding the top-left cell
    in property <[string]> row_headers;
    // The number of pages to show
    in property <int> num_pages;
    // The source of the data, i.e. what ram (WRAM, VRAM) is being displayed
    in-out property <BinaryDataSource> source;

    function header_color() -> color {
        if (source.ramType == BinaryDataSourceType.Wram) {
            return Palette.wramHeader;
        } else if (source.ramType == BinaryDataSourceType.Vram) {
            return Palette.vramHeader;
        } else if (source.ramType == BinaryDataSourceType.Cgram) {
            return Palette.cgramHeader;
        } else if (source.ramType == BinaryDataSourceType.Cartridge) {
            return Palette.cartridgeHeader;
        }
        return Colors.white;
    }

    function change_page(amount: int) {
        source.page-offset = min(
            max(0, source.page-offset + amount), num_pages - 1);
    }

    VerticalLayout {
        HorizontalLayout {
            alignment: start;
            ComboBox {
                model: ["WRAM", "VRAM", "CGRAM", "Cartridge"];
                selected(value) => {
                    if (value == "WRAM") {
                        source.ramType = BinaryDataSourceType.Wram
                    } else if (value == "VRAM") {
                        source.ramType = BinaryDataSourceType.Vram
                    } else if (value == "CGRAM") {
                        source.ramType = BinaryDataSourceType.Cgram
                    } else if (value == "Cartridge") {
                        source.ramType = BinaryDataSourceType.Cartridge
                    }
                    source.page-offset = 0;
                }
            }

            Button {
                text: "-16";
                clicked => {
                    change_page(-16)
                }
                enabled: source.page-offset >= 16;
            }

            Button {
                text: "-1";
                clicked => {
                    change_page(-1);
                }
                enabled: source.page-offset != 0;
            }

            // Required for padding
            VerticalLayout {
                padding-left: 10px;
                padding-right: 10px;
                Text {
                    text: "Page " + source.page-offset;
                    vertical-alignment: center;
                }
            }

            Button {
                text: "+1";
                clicked => {
                    change_page(1)
                }
                enabled: source.page-offset != num_pages - 1;
            }

            Button {
                text: "+16";
                clicked => {
                    change_page(16)
                }
                enabled: source.page-offset < num_pages - 16;
            }

            CheckBox {
                checked <=> source.show-as-tile;
                text: "Interpret as tile data";
            }
        }

        if source.show-as-tile: Image {
            source: data_image;
            image-rendering: ImageRendering.pixelated;
        }
        if !source.show-as-tile: GridLayout {
            padding: 10px;
            // Header row
            Row {
                for header[j] in column_headers: Text {
                    text: header;
                    color: header_color();
                    font-weight: FontWeight.bold;
                    horizontal-alignment: j == 0 ? left : right;
                }
            }

            for row_data[i] in data: Row {
                Text {
                    text: row_headers[i];
                    color: header_color();
                    horizontal-alignment: left;
                }

                for byte[j] in row_data: Text {
                    text: byte;
                    font-weight: byte == "00" ? FontWeight.extra-light : FontWeight.normal;
                    horizontal-alignment: right;
                }
            }
        }
    }
}
