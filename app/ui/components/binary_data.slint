import { ComboBox, Button, CheckBox, TabWidget } from "std-widgets.slint";
import { Palette } from "../palette.slint";
import { Fmt } from "../globals.slint";

// Types of binary data sources
export enum BinaryDataSrc {
    Wram,
    Vram,
    Aram,
    Cgram,
    Cartridge
}
/*
 * View Binary data as a table of bytes
 */
export component BinaryData {
    // The section of binary data to display, as hex strings
    in property <[[int]]> data;
    // The section binary data to display, as an image
    in property <image> data_image;
    // The offset of the binary data
    out property <int> offset;
    // The length of the data to show
    in property <int> data_len;
    property <int> num_palettes: 64;
    property <int> tab_index;
    out property <BinaryDataSrc> data_src;
    out property <int> bpp;
    out property <int> palette_index;

    init => {
        data_src = BinaryDataSrc.Wram;
        bpp = 2;
        palette_index = 0;
        offset = 0;
    }

    // Derived property for the offset to display
    property <int> display_offset: (data_src == BinaryDataSrc.Wram ? 8257536 : 0) + offset;

    function set_bpp(new_bpp: int) {
        bpp = new_bpp;
        if (bpp == 2) {
            num_palettes = 64;
        } else if (bpp == 4) {
            num_palettes = 16;
        } else {
            num_palettes = 1;
        }
        palette_index = clamp(palette_index, 0, num_palettes - 1);
    }

    function header_color() -> color {
        if (data_src == BinaryDataSrc.Wram) {
            return Palette.cpu;
        } else if (data_src == BinaryDataSrc.Vram) {
            return Palette.ppu;
        } else if (data_src == BinaryDataSrc.Cgram) {
            return Palette.ppu;
        } else if (data_src == BinaryDataSrc.Cartridge) {
            return Palette.cartridge;
        } else if (data_src == BinaryDataSrc.Aram) {
            return Palette.apu;
        }
        return Colors.white;
    }

    function change_page(amount: int) {
        let per_page = 8 * 32;
        offset = clamp(offset + per_page * amount, 0, data_len);
    }

    VerticalLayout {
        HorizontalLayout {
            alignment: start;
            ComboBox {
                model: ["WRAM", "VRAM", "CGRAM", "ARAM", "Cartridge"];
                selected(value) => {
                    if (value == "WRAM") {
                        data_src = BinaryDataSrc.Wram
                    } else if (value == "VRAM") {
                        data_src = BinaryDataSrc.Vram
                    } else if (value == "CGRAM") {
                        data_src = BinaryDataSrc.Cgram
                    } else if (value == "ARAM") {
                        data_src = BinaryDataSrc.Aram;
                    } else if (value == "Cartridge") {
                        data_src = BinaryDataSrc.Cartridge
                    }
                    offset = 0;
                }
            }

            Button {
                text: "-16";
                clicked => {
                    change_page(-16)
                }
            }

            Button {
                text: "-1";
                clicked => {
                    change_page(-1);
                }
            }

            // Required for padding
            VerticalLayout {
                padding-left: 10px;
                padding-right: 10px;
                Text {
                    text: Fmt.address(offset);
                    vertical-alignment: center;
                }
            }

            Button {
                text: "+1";
                clicked => {
                    change_page(1)
                }
            }

            Button {
                text: "+16";
                clicked => {
                    change_page(16)
                }
            }

            ComboBox {
                model: ["2BPP", "4BPP", "8BPP"];
                selected(value) => {
                    if (value == "2BPP") {
                        set_bpp(2);
                    } else if (value == "4BPP") {
                        set_bpp(4);
                    } else if (value == "8BPP") {
                        set_bpp(8);
                    }
                }
            }

            Button {
                text: "-1";
                clicked => {
                    palette_index = max(palette_index - 1, 0);
                }
            }

            VerticalLayout {
                alignment: center;
                Text {
                    text: "Palette " + palette_index;
                }
            }

            Button {
                text: "+1";
                clicked => {
                    palette_index = min(palette_index + 1, num_palettes - 1);
                }
            }
        }

        TabWidget {
            current-index <=> tab_index;
            Tab {
                title: "Data";
                GridLayout {
                    padding: 10px;
                    Row {
                        Text {
                            text: Fmt.address(display_offset);
                            color: header_color();
                            font-weight: FontWeight.bold;
                            horizontal-alignment: left;
                        }

                        for j in 32: Text {
                            text: "+" + Fmt.byte(j);
                            color: header_color();
                            horizontal-alignment: right;
                        }
                    }

                    for row_data[i] in data: Row {
                        Text {
                            text: Fmt.address(display_offset + 32 * i);
                            color: header_color();
                            horizontal-alignment: left;
                        }

                        for byte[j] in row_data: Text {
                            text: Fmt.byte(byte);
                            color: byte == 0 ? Palette.light_grey : Palette.white;
                            horizontal-alignment: right;
                        }
                    }
                }
            }

            Tab {
                title: "Tiles";
                Image {
                    source: data_image;
                    image-rendering: ImageRendering.pixelated;
                    width: 100%;
                    height: 100%;
                }
            }
        }
    }
}
