import { ComboBox } from "std-widgets.slint";

export enum BinaryDataSource {
    Wram,
    Vram,
    Cgram,
    Cartridge
}
/*
 * View Binary data in several formats
 */
export component BinaryData {
    // The binary data to display
    in property <[[string]]> data;
    in-out property <BinaryDataSource> source;

    VerticalLayout {
        HorizontalLayout {
            ComboBox {
                model: ["WRAM", "VRAM", "CGRAM", "Cartridge"];
                selected(value) => {
                    if (value == "WRAM") {
                        source = BinaryDataSource.Wram
                    } else if (value == "VRAM") {
                        source = BinaryDataSource.Vram
                    } else if (value == "CGRAM") {
                        source = BinaryDataSource.Cgram
                    } else if (value == "Cartridge") {
                        source = BinaryDataSource.Cartridge
                    }
                }
            }
        }

        GridLayout {
            for row_data[i] in data: Row {
                for byte[j] in row_data: Text {
                    text: byte;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
